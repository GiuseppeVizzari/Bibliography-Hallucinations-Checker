# Flask secret key (required for session cookies & CSRF protection)
# Generate with: python -c "import secrets; print(secrets.token_hex(16))"
SECRET_KEY=your-secret-key-here

# OpenAlex Email (Optional, but recommended for faster responses)
# Sets the email header for OpenAlex API requests, giving access to the "polite pool".
OPENALEX_EMAIL=your-email@example.com

# OpenAlex API key (Optional, for higher rate limits)
OPENALEX_API_KEY=your-api-key

# Set to '1' to enable Flask debug mode (NOT recommended for production)
FLASK_DEBUG=0
